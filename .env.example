# Copy this file to .env and fill in the values
# All EXPO_PUBLIC_ variables are bundled into the client — do NOT put secrets here

# Use mock API mode for local development (default — no backend required)
EXPO_PUBLIC_API_MODE=mock

# Uncomment and set this to connect to a real backend instead
# EXPO_PUBLIC_API_URL=https://api.instaapp.com/v1
